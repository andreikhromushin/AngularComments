{
  "name": "angular-comments",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "21.2.14",
    "@angular/compiler": "21.2.14",
    "@angular/core": "21.2.14",
    "@angular/forms": "21.2.14",
    "@angular/platform-browser": "21.2.14",
    "@angular/router": "21.2.14",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.12",
    "@angular/cli": "21.2.12",
    "@angular/compiler-cli": "21.2.14",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "typescript": "5.9.2",
    "vitest": "4.1.7"
  }
}
